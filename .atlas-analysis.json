  "keyFeatures": [
    "Type-safe TypeScript bindings for the full Podman libpod REST API",
    "Bun-native implementation using Unix socket and TCP connections",
    "High-level resource managers for containers, images, pods, networks, volumes, secrets, manifests, quadlets, and artifacts",
    "Streaming support for logs and events via async iterators",
    "Kubernetes YAML generation and apply via kube manager",
    "Docker-compatible client alias for drop-in replacement",
    "Environment-based connection via CONTAINER_HOST / DOCKER_HOST",
    "Named connection support via containers.conf / podman-connections.json",
    "OCI artifact management (add, pull, push, extract)",
    "Low-level APIClient for arbitrary libpod/compat requests"
  ],
